rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - deny access to any other collections
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public read/write access to application collections
    // This is safe because only the Express server has access to the database configuration/credentials
    match /news/{document} {
      allow read, write: if true;
    }
    match /opinions/{document} {
      allow read, write: if true;
    }
    match /events/{document} {
      allow read, write: if true;
    }
    match /directory/{document} {
      allow read, write: if true;
    }
    match /emergency/{document} {
      allow read, write: if true;
    }
    match /notices/{document} {
      allow read, write: if true;
    }
    match /lpgDeliveries/{document} {
      allow read, write: if true;
    }
    match /autos/{document} {
      allow read, write: if true;
    }
    match /destinations/{document} {
      allow read, write: if true;
    }
    match /cultures/{document} {
      allow read, write: if true;
    }
    match /stays/{document} {
      allow read, write: if true;
    }
    match /travelogues/{document} {
      allow read, write: if true;
    }
    match /photos/{document} {
      allow read, write: if true;
    }
    match /busRoutes/{document} {
      allow read, write: if true;
    }
    match /routes/{document} {
      allow read, write: if true;
    }
    match /metadata/{document} {
      allow read, write: if true;
    }
  }
}
